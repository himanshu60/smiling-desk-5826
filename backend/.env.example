# Copy this file to `.env` and fill in real values. Do NOT put real secrets here — this file is committed.

# Server port (standard uppercase PORT so cloud hosts inject it automatically)
PORT=8080

# MongoDB Atlas connection string
mongoUrl=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# Secret used to sign/verify JWTs
key=replace-with-a-long-random-secret
